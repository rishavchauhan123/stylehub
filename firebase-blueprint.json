{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Men", "Women", "Accessories"] },
        "costPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "stock": { "type": "integer" },
        "lowStockThreshold": { "type": "integer" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "category", "costPrice", "sellingPrice", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" },
              "cost": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "profit": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Card", "UPI"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNumber", "items", "total", "profit", "paymentMethod", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Inventory purchase from supplier",
      "type": "object",
      "properties": {
        "supplierName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" },
              "cost": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierName", "items", "total", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "totalSpent": { "type": "number" },
        "lastPurchaseAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense record",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "amount", "date"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "System activity log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Inventory items" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales records" },
    "/purchases/{purchaseId}": { "schema": "Purchase", "description": "Purchase orders" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer database" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Expense records" },
    "/activity_logs/{logId}": { "schema": "ActivityLog", "description": "System logs" }
  }
}
